{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "超级智能办公室",
  "version": "0.1.0",
  "identifier": "com.shinmuchen.agentsalon",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "超级智能办公室 · Super Intelligence Office",
        "width": 1480,
        "height": 940,
        "minWidth": 1200,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
